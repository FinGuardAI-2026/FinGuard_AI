# ── FinGuard AI Global Environment Configuration ───────────────────────────────
# Copy this file to .env, .env.development, or .env.production as needed.

# Application Core Settings
APP_NAME="FinGuard AI"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG=true

# Server Networking
HOST="0.0.0.0"
PORT=8000

# Database Connection
DATABASE_URL="mongodb://localhost:27017/finguard"

# Security & Authentication
SECRET_KEY="replace-this-with-a-secure-random-secret-key-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI & LLM Integrations
GEMINI_API_KEY="your-google-gemini-api-key-here"

# Frontend Configuration
VITE_API_BASE_URL="http://localhost:8000"
