PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development
DEBUG=true
APP_NAME=FinGuard AI
APP_VERSION=1.0.0

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/finguard?retryWrites=true&w=majority
DATABASE_NAME=finguard

# Security - CHANGE THESE IN PRODUCTION
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-this-with-a-strong-random-secret-key-at-least-32-chars

# Google Gemini
GEMINI_API_KEY=your-google-gemini-api-key-here
